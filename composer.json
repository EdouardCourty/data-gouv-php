{
    "name": "ecourty/data-gouv-php",
    "description": "A PHP client library for the data.gouv.fr API.",
    "type": "library",
    "keywords": ["data.gouv.fr", "api", "client", "php"],
    "require": {
        "php": ">=8.4",
        "jane-php/open-api-runtime": "^7.0",
        "php-http/client-common": "^2.7",
        "symfony/http-client": "^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.71",
        "jane-php/open-api-2": "^7.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ecourty\\DataGouv\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ecourty\\DataGouv\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Edouard Courty",
            "email": "edouard.courty2@gmail.com",
            "homepage": "https://github.com/EdouardCourty"
        }
    ],
    "scripts": {
        "generate:patch-spec": "php bin/patch-spec.php",
        "generate:client": "php vendor/bin/jane-openapi generate",
        "generate:patch-generated": "php bin/patch-generated.php",
        "generate:facade": "php bin/generate-facade.php",
        "generate": [
            "@generate:patch-spec",
            "@generate:client",
            "@generate:patch-generated",
            "@generate:facade",
            "@cs-fix"
        ],
        "test": "phpunit tests",
        "test-unit": "phpunit tests/Unit/",
        "test-functional": "phpunit tests/Functional/",
        "test-integration": "phpunit tests/Integration/",
        "test-fast": "@test-unit",
        "phpstan": "phpstan analyse --memory-limit=-1",
        "cs-fix": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix . --config .php-cs-fixer.php",
        "cs-check": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix . --config .php-cs-fixer.php --dry-run --diff",
        "qa": [
            "@phpstan",
            "@cs-check",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
