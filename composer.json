{
    "name": "ecourty/data-gouv-client",
    "description": "A PHP client library for the data.gouv.fr API.",
    "type": "library",
    "keywords": [
        "data.gouv.fr",
        "api",
        "client",
        "php",
        "data-gouv"
    ],
    "require": {
        "php": ">=8.4",
        "jane-php/open-api-runtime": "^7.0",
        "php-http/client-common": "^2.7",
        "symfony/http-client": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.71",
        "jane-php/open-api-2": "^7.0",
        "jane-php/open-api-3": "^7.0",
        "jane-php/open-api-3-1": "^7.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0",
        "symfony/console": "^8.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ecourty\\DataGouv\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ecourty\\DataGouv\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Edouard Courty",
            "email": "edouard.courty2@gmail.com",
            "homepage": "https://github.com/EdouardCourty"
        }
    ],
    "scripts": {
        "generate": [
            "php bin/console generate",
            "@cs-fix"
        ],
        "add-api": "php bin/console add-api",
        "validate-registry": "php bin/console validate-registry",
        "test": "phpunit tests",
        "test-unit": "phpunit tests/Unit/",
        "test-functional": "phpunit tests/Functional/",
        "test-integration": "phpunit tests/Integration/",
        "test-fast": "@test-unit",
        "phpstan": "phpstan analyse --memory-limit=-1",
        "cs-fix": "php-cs-fixer fix --config .php-cs-fixer.php",
        "cs-check": "php-cs-fixer fix --config .php-cs-fixer.php --dry-run --diff",
        "qa": [
            "@phpstan",
            "@cs-check",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
