#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Ecourty\DataGouv\Generator\Command\AddApiCommand;
use Ecourty\DataGouv\Generator\Command\GenerateCommand;
use Ecourty\DataGouv\Generator\Command\ValidateIntegrationCoverageCommand;
use Ecourty\DataGouv\Generator\Command\ValidateRegistryCommand;
use Symfony\Component\Console\Application;

$app = new Application('data-gouv-client', '1.0.0');
$app->addCommand(new GenerateCommand());
$app->addCommand(new AddApiCommand());
$app->addCommand(new ValidateRegistryCommand());
$app->addCommand(new ValidateIntegrationCoverageCommand());
$app->setDefaultCommand('list');
$app->run();
